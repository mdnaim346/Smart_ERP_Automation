<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_smart_automation" model="ir.module.category">
        <field name="name">Smart ERP Automation</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_smart_automation_user" model="res.groups">
        <field name="name">Automation User</field>
        <field name="category_id" ref="module_category_smart_automation"/>
    </record>

    <record id="group_smart_automation_manager" model="res.groups">
        <field name="name">Automation Manager</field>
        <field name="category_id" ref="module_category_smart_automation"/>
        <field name="implied_ids" eval="[(4, ref('group_smart_automation_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
