<odoo>
  <record id="cron_auto_invoice" model="ir.cron">
    <field name="name">Auto Invoice</field>
    <field name="model_id" ref="sale.model_sale_order"/>
    <field name="state">code</field>
    <field name="code">model.auto_generate_invoice()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">hours</field>
  </record>
  <record id="cron_run_automation" model="ir.cron">
    <field name="name">Run Automation Rules</field>
    <field name="model_id" ref="model_automation_rule"/>
    <field name="state">code</field>
    <field name="code">model.run_automation()</field>
    <field name="interval_number">10</field>
    <field name="interval_type">minutes</field>
</record>
</odoo>